# .gitignore — 任務管理系統

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── 虛擬環境 ──────────────────────────────────
.venv/
venv/
env/

# ── 環境變數（含機密資訊，不納入版控）────────
.env

# ── SQLite 資料庫（執行期資料）────────────────
instance/
*.db
*.sqlite3

# ── IDE / 編輯器 ──────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ────────────────────────────────────
.DS_Store

# ── Windows ──────────────────────────────────
Thumbs.db
